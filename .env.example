# Plantilla de variables de entorno.
# Copiá este archivo como .env y completá los valores reales.
# El .env NUNCA se commitea (está en .gitignore).

# --- API de Anthropic (Claude) ---
# Obtené tu key en https://console.anthropic.com
ANTHROPIC_API_KEY=

# Modelo a usar. Por defecto, el más economico disponible (familia Haiku).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Transcripción (Groq / Whisper, free tier) ---
# Obtené tu key gratis en https://console.groq.com (empieza con gsk_...)
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3-turbo
TRANSCRIBE_LANG=es

# --- Flask ---
# Clave secreta para sesiones/seguridad. Poné un string largo y aleatorio.
FLASK_SECRET_KEY=

# --- Base de datos ---
# En producción (Render) usá Postgres de Neon pegando acá la URL de conexión.
# Si la dejás vacía, la app usa SQLite local (ideal para desarrollo).
# Ejemplo Neon: postgresql://usuario:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Ruta del archivo SQLite (solo se usa si DATABASE_URL está vacía)
DATABASE_PATH=grabadora.db
