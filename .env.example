# Plantilla de variables de entorno.
# Copiá este archivo como .env y completá los valores reales.
# El .env NUNCA se commitea (está en .gitignore).

# --- API de Anthropic (Claude) ---
# Obtené tu key en https://console.anthropic.com
ANTHROPIC_API_KEY=

# Modelo a usar. Por defecto, el más economico disponible (familia Haiku).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Flask ---
# Clave secreta para sesiones/seguridad. Poné un string largo y aleatorio.
FLASK_SECRET_KEY=

# --- Base de datos ---
# Ruta del archivo SQLite (opcional; por defecto grabadora.db)
DATABASE_PATH=grabadora.db
